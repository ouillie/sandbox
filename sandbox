#!/usr/bin/env bash

set -euo pipefail

# Iterate up the directory tree, looking for sibling directories named `.sandbox`.
# In each of those directories, process the following files:
# - `proxy.py`: Loaded as an mitmproxy addon.
# - `configure.sh`: Settings configuration for the sandbox.
proxy_addon_mounts=()
configure_paths=()
directory="${PWD}"
index=1
while
  proxy_addon="${directory}/.sandbox/proxy.py"
  if [ -f "${proxy_addon}" ]
  then
    proxy_destination="/root/addons/$(printf '%03d' "${index}").py"
    proxy_addon_mounts+=(--volume="${proxy_addon}":"${proxy_destination}":ro)
  fi

  configure_path="${directory}/.sandbox/configure.sh"
  if [ -f "${configure_path}" ]
  then
    configure_paths+=("${configure_path}")
  fi

  [ "${directory}" != '/' ]
do
  directory="$(dirname "${directory}")"
  index=$(( index + 1 ))
done

# The workload's network is internal: it has no route to the internet of its own,
# so the proxy (its only neighbor, dual-homed onto the egress network) is the only way out.
wireguard_network="$(podman network create --internal)"
egress_network="$(podman network create)"

function cleanup-networks {
  podman network rm "${wireguard_network}" "${egress_network}" >/dev/null 2>&1 || true
}
trap cleanup-networks EXIT

# `mitmweb` always requires auth (setting an empty password just makes it generate a random one).
# Pin a known password and let the launcher pass it as `?token=` to skip the prompt.
mitmweb_password='sandbox'

proxy_container="$(
  podman run \
    --detach --rm \
    --user=root \
    --network="${wireguard_network}" \
    --network="${egress_network}" \
    --volume=/root/.mitmproxy \
    "${proxy_addon_mounts[@]}" \
    --publish=127.0.0.1::8081 \
    mitmproxy/mitmproxy:latest \
    bash -c '
      arguments=(
        --mode=wireguard
        --set=web_password="${0}"
        --web-host=0.0.0.0
        --no-web-open-browser
        # Use the `Host` header to construct URLs for display.
        --set=showhost=true
      )
      shopt -s nullglob
      for script in "${HOME}"/addons/*.py
      do
        arguments+=(--scripts="${script}")
      done
      exec mitmweb "${arguments[@]}"
    ' "${mitmweb_password}"
)"

function cleanup-proxy-container {
  podman rm -f "${proxy_container}" >/dev/null 2>&1 || true
  cleanup-networks
}
trap cleanup-proxy-container EXIT

# Wait for mitmproxy to generate its CA and WireGuard keys.
mitmproxy_ca_path='/root/.mitmproxy/mitmproxy-ca-cert.pem'
timeout=5
start=$(date +%s)
until podman exec "${proxy_container}" test -f "${mitmproxy_ca_path}" 2>/dev/null
do
  sleep 0
  now=$(date +%s)
  if (( now - start > timeout ))
  then
    echo "Failed to start proxy pod after ${timeout} seconds" >&2
    exit 1
  fi
done

echo "Network monitor: http://$(podman port "${proxy_container}" 8081)/?token=${mitmweb_password}" >&2

# The proxy's address is the WireGuard endpoint. mitmproxy stores both private
# keys, so derive the server's public key (which the workload's peer needs).
proxy_ip="$(podman inspect --format="{{(index .NetworkSettings.Networks \"${wireguard_network}\").IPAddress}}" "${proxy_container}")"
read -r server_key client_key < <(podman exec "${proxy_container}" python -c \
  'import json, mitmproxy_rs; c = json.load(open("/root/.mitmproxy/wireguard.conf")); print(mitmproxy_rs.wireguard.pubkey(c["server_key"]), c["client_key"])')

# Sandbox container image.
SANDBOX_IMAGE="${SANDBOX_IMAGE:-debian:latest}"
# Sandbox container username.
SANDBOX_USER="${SANDBOX_USER:-root}"
# Sandbox container hostname.
SANDBOX_HOSTNAME="${SANDBOX_HOSTNAME:-sandbox}"
# Working directory in the sandbox at entry.
# By default, use the current working directory on the host.
# If that path starts with the host's `${HOME}` path, swap out the prefix for `/root`,
# because the process in the sandbox runs as root by default.
if [ -z "${SANDBOX_WORKDIR+.}" ]
then
  case "${PWD}" in
    "${HOME}"|"${HOME}"/*)
      SANDBOX_WORKDIR="${PWD/#${HOME}//root}"
      ;;
    *)
      SANDBOX_WORKDIR="${PWD}"
      ;;
  esac
fi
# Array of mount points to bind-mount from the host into the sandbox,
# using Podman's `<host-path>:<guest-path>[:<mode>]` syntax,
# where `<mode>` can be `ro`, `rw`, or `O` (overlay).
# By default, mount the host's `${HOME}` directory to `/root` as an overlay,
# and mount the host's working directory to the guest's working directory read-write.
if [ -z "${SANDBOX_MOUNTS[@]+.}" ]
then
  declare -a SANDBOX_MOUNTS=(
    "${HOME}":'/root':O
    "${PWD}":"${SANDBOX_WORKDIR}":rw
  )
fi
# Array of environment variables to set in the sandbox
# using Podman's `NAME=VALUE` or simply `NAME` syntax.
# By default, set various environment variables to trust the proxy's ephemeral CA in most apps,
# since the proxy intercepts all network traffic, terminating TLS if necessary.
# Also set `IS_SANDBOX=1`
# which is required by Claude Code to run as root with `--dangerously-skip-permissions`.
# https://github.com/anthropics/claude-code/issues/9184
if [ -z "${SANDBOX_ENV[@]+.}" ]
then
  declare -a SANDBOX_ENV=(
    SSL_CERT_FILE="${mitmproxy_ca_path}"
    CURL_CA_BUNDLE="${mitmproxy_ca_path}"
    GIT_SSL_CAINFO="${mitmproxy_ca_path}"
    CARGO_HTTP_CAINFO="${mitmproxy_ca_path}"
    NODE_EXTRA_CA_CERTS="${mitmproxy_ca_path}"
    REQUESTS_CA_BUNDLE="${mitmproxy_ca_path}"
    IS_SANDBOX=1
  )
fi

# Process the user's configuration scripts from root to leaf.
for (( i=${#configure_paths[@]}-1; i>=0; i-- ))
do
  source "${configure_paths[i]}"
done

# A pod owns the sandbox' network namespace.
# A throwaway container will configure the WireGuard tunnel inside the pod before the sandbox starts.
sandbox_pod="$(podman pod create --network="${wireguard_network}" --hostname="${SANDBOX_HOSTNAME}")"

function cleanup-pod {
  podman pod rm -f "${sandbox_pod}" >/dev/null 2>&1 || true
  cleanup-proxy-container
}
trap cleanup-pod EXIT

# Set up the WireGuard tunnel to the proxy in the sandbox pod's namespace.
podman run \
  --rm \
  --pod="${sandbox_pod}" \
  --cap-add=NET_ADMIN \
  mitmproxy/mitmproxy:latest \
  bash -c '
    ip link add wg0 type wireguard
    wg set wg0 private-key <(echo "${1}") peer "${2}" endpoint "${3}:51820" allowed-ips 0.0.0.0/0
    ip address add 10.0.0.1/32 dev wg0
    ip link set wg0 up
    ip route replace default dev wg0
  ' "${0}" "${client_key}" "${server_key}" "${proxy_ip}"

declare -a arguments=()
if [ -t 0 ]
then
  arguments+=(--tty)
fi

# Join the configured namespace and run the command. The CA env vars cover runtimes
# (Node, Python requests, ...) that ignore the system store; the copy below covers
# those that only read the default OpenSSL bundle.
podman run \
  --interactive --rm \
  "${arguments[@]}" \
  --pod="${sandbox_pod}" \
  --volumes-from="${proxy_container}":ro \
  --user="${SANDBOX_USER}" \
  --workdir="${SANDBOX_WORKDIR}" \
  "${SANDBOX_MOUNTS[@]/#/--volume=}" \
  "${SANDBOX_ENV[@]/#/--env=}" \
  "${SANDBOX_IMAGE}" \
  bash -c '
    echo "nameserver 10.0.0.53" >/etc/resolv.conf

    for ca_certificates in /etc/ssl/certs/ca-certificates.crt /etc/pki/tls/certs/ca-bundle.crt
    do
      if [ -f "${ca_certificates}" ]
      then
        cp "${1}" "${ca_certificates}"
      fi
    done

    shift
    if (( $# == 0 ))
    then
      exec "${SHELL:-/usr/bin/bash}"
    else
      exec "$@"
    fi
  ' "${0}" "${mitmproxy_ca_path}" "$@"
